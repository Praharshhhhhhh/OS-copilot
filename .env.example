# GROQ_API_KEY: Required for Groq API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GITHUB_CLIENT_ID and GITHUB_CLIENT_SECRET
# Register an OAuth app on GitHub (https://github.com/settings/developers)
# Use your APP_URL + /auth/callback as the Authorization callback URL.
GITHUB_CLIENT_ID="YOUR_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="YOUR_GITHUB_CLIENT_SECRET"

